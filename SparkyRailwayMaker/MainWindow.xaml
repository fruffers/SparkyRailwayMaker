<Window x:Class="SparkyRailwayMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SparkyRailwayMaker"
        mc:Ignorable="d"
        Background="Black"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Title Text -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,20">
            <TextBlock Text="Sparky " FontSize="24" FontWeight="Bold" Foreground="Lime"/>
            <TextBlock Text="Railway " FontSize="24" FontWeight="Bold" Foreground="Yellow"/>
            <TextBlock Text="Maker" FontSize="24" FontWeight="Bold" Foreground="Red"/>
        </StackPanel>

        <!-- Button Row -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Start" 
                    FontSize="20" Margin="20" Width="150" Height="60"/>
            <Button Grid.Column="1" Content="Load" 
                    FontSize="20" Margin="20" Width="150" Height="60"/>
            <Button Grid.Column="2" Content="Instructions" 
                    FontSize="20" Margin="20" Width="150" Height="60"/>
        </Grid>
    </Grid>
</Window>
